{
  "name": "stud-cli",
  "version": "0.0.1",
  "description": "A bare-bones, 100% customizable and extensible coding CLI tool. Placeholder release — architecture in progress.",
  "bin": {
    "stud-cli": "bin/stud-cli.js"
  },
  "files": [
    "bin",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "cli",
    "stud-cli",
    "ai-sdk",
    "agent",
    "extensible"
  ],
  "author": "Mark Huang",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Z-M-Huang/stud-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Z-M-Huang/stud-cli/issues"
  },
  "homepage": "https://github.com/Z-M-Huang/stud-cli#readme",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsc -p tsconfig.json",
    "test:node": "node --test --test-reporter=spec tests/**/*.test.ts",
    "test:bun": "bun test",
    "test": "bun run test:node",
    "audit": "bun audit --audit-level=high",
    "prepublishOnly": "bun install --frozen-lockfile && bun run audit && bun run typecheck && bun run lint && bun run test && bun run build"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.12",
    "@types/node": "22.19.17",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-security": "4.0.0",
    "lefthook": "2.1.6",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2"
  },
  "trustedDependencies": []
}
