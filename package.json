{
  "name": "stud-cli",
  "version": "0.1.0",
  "description": "A bare-bones, 100% customizable and extensible coding CLI tool. Placeholder release — architecture in progress.",
  "bin": {
    "stud-cli": "bin/stud-cli.js"
  },
  "files": [
    "bin",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "cli",
    "stud-cli",
    "ai-sdk",
    "agent",
    "extensible"
  ],
  "author": "Mark Huang",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Z-M-Huang/stud-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Z-M-Huang/stud-cli/issues"
  },
  "homepage": "https://github.com/Z-M-Huang/stud-cli#readme",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsc -p tsconfig.json",
    "test:node": "node --import tsx --test --test-force-exit --test-reporter=spec",
    "test:bun": "bun test",
    "test": "node --import tsx --test --test-force-exit --test-reporter=spec",
    "test:coverage": "c8 --reporter=json-summary --report-dir=coverage node --import tsx --test --test-force-exit && node --import tsx scripts/coverage-gate.ts coverage/coverage-summary.json",
    "audit": "bun audit --audit-level=high",
    "banned-vocab": "node --import tsx scripts/banned-vocab.ts",
    "ban-bun-globals": "node --import tsx scripts/ban-bun-globals.ts",
    "boundary-check": "node --import tsx scripts/boundary-check.ts",
    "examples-check": "node --import tsx scripts/examples-check.ts",
    "prepublishOnly": "bun install --frozen-lockfile && bun run audit && bun run typecheck && bun run lint && bun run test && bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "agentool": "^1.3.0",
    "ai": "6.0.168",
    "ink": "7.0.1",
    "react": "19.2.5",
    "react-devtools-core": "6.1.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.12",
    "@types/node": "22.19.17",
    "@types/react": "19.2.14",
    "ajv": "6.14.0",
    "c8": "11.0.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-security": "4.0.0",
    "lefthook": "2.1.6",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2"
  },
  "trustedDependencies": []
}
