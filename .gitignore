# Source is TypeScript-only; emit goes to dist/. Tests run via `node --import tsx`
# which resolves `.js` → `.ts` directly, so no .js/.d.ts artefacts belong under
# src/, tests/, or scripts/. Ignored across all three to prevent stray emit from
# shadowing .ts source.
src/**/*.js
src/**/*.js.map
src/**/*.d.ts
src/**/*.d.ts.map
tests/**/*.js
tests/**/*.js.map
tests/**/*.d.ts
tests/**/*.d.ts.map
scripts/*.js
scripts/*.js.map
scripts/*.d.ts
scripts/*.d.ts.map